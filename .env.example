# consumed by the postgres image (db service)
POSTGRES_DB=tickets
POSTGRES_USER=tickets
POSTGRES_PASSWORD=tickets

# consumed by the Spring datasource (backend service) - same DB, JDBC form
DATABASE_URL=jdbc:postgresql://db:5432/tickets
DB_USER=tickets
DB_PASSWORD=tickets

# origins allowed to call the API directly with a cross-origin request (dev servers,
# or a deployed frontend origin not proxied same-origin through nginx); comma-separated
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
